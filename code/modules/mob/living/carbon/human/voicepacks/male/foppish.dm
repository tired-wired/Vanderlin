				used = list('sound/vo/male/foppish/cry (1).ogg','sound/vo/male/foppish/cry (2).ogg','sound/vo/male/foppish/cry (3).ogg')
			if("fatigue")
				used = 'sound/vo/male/foppish/fatigue.ogg'
			if("gasp")
