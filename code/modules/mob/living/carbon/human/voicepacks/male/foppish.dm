/datum/voicepack/male/foppish/get_sound(soundin, modifiers)
	var/used
	switch(modifiers)
		if("old")
			used = getmold(soundin)
		if("silenced")
			used = getmsilenced(soundin)
	if(!used)
		switch(soundin)
			if("cackle")
				used = list('sound/vo/male/foppish/cackle (1).ogg','sound/vo/male/foppish/cackle (2).ogg')
			if("chuckle")
				used = list('sound/vo/male/foppish/chuckle (1).ogg','sound/vo/male/foppish/chuckle (2).ogg','sound/vo/male/foppish/chuckle (3).ogg')
